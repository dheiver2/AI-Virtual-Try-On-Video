# Replicate API para Virtual Try-On (Gratuito)
# Obtenha sua chave em: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN="seu_token_aqui"

# Opcional: caminho absoluto do ffmpeg se o Node nao encontrar no PATH
# Exemplo WSL: FFMPEG_PATH="/usr/bin/ffmpeg"
# Exemplo Windows/WSL: FFMPEG_PATH="/mnt/c/Users/seu_usuario/ffmpeg/bin/ffmpeg.exe"
FFMPEG_PATH=""
